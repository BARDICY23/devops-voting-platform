{
  "uid": "voting-cluster",
  "title": "Voting App - Cluster Overview",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU usage (voting namespace) - cores",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"voting\", container!=\"\", image!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Memory usage (voting namespace) - bytes",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"voting\", container!=\"\", image!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Restarts (voting namespace) - increase over 10m",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"voting\"}[10m])) by (pod, container)",
          "legendFormat": "{{pod}}/{{container}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 18
      }
    }
  ]
}
